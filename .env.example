# Copy to .env (gitignored), then run:
#   node scripts/generate-local-config.mjs
#
# On localhost, the app loads config.local.js when present. Production GitHub Pages
# uses config.js only (public API URL; Cognito via GET /auth/config when blank).

WQT_API_BASE_URL=https://gnewkvhgwd.execute-api.eu-west-1.amazonaws.com/prod
WQT_COGNITO_DOMAIN=
WQT_COGNITO_CLIENT_ID=
WQT_COGNITO_SCOPES=openid email profile

# Legacy optional file (also gitignored): deploy/api-url-and-key.txt
# The generator merges keys from that file when .env omits them.

# Do not put API Gateway usage-plan keys here for the browser. Protected routes use
# Authorization: Bearer <JWT>. API keys belong in deploy tooling only, not index.html.
